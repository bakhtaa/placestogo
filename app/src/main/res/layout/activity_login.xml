<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#B8D8D8">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🗺️ FavPlaces"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#4A5940"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vos lieux favoris"
        android:textSize="16sp"
        android:textColor="#6B7F6B"
        android:layout_marginBottom="32dp"/>

    <!-- Onglets -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/btnTabLogin"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="Connexion"
            android:backgroundTint="#7ECECA"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnTabRegister"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="Inscription"
            android:backgroundTint="#C4B8D8"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

    <EditText
        android:id="@+id/etUsername"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Nom d'utilisateur"
        android:padding="12dp"
        android:background="@drawable/rounded_input"
        android:inputType="text"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Mot de passe"
        android:padding="12dp"
        android:background="@drawable/rounded_input"
        android:inputType="textPassword"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnAction"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Se connecter"
        android:textSize="18sp"
        android:backgroundTint="#7ECECA"
        android:textColor="#FFFFFF"/>

</LinearLayout>